file":{"filePath":"/home/jwilger/projects/todo_list/templates/todos.html","content":"{% extends \"base.html\" %}\n\n{% block title %}My Todos -- Todo List{% endblock %}\n\n{% block nav %}\n<form method=\"post\" action=\"/logout\" class=\"nav-logout\">\n    <button type=\"submit\" class=\"nav-logout__button\">Sign out</button>\n</form>\n{% endblock %}\n\n{% block content %}\n<div class=\"todo-page\">\n    <h1>My Todos</h1>\n\n    <form method=\"post\" action=\"/todos\" class=\"todo-add\">\n        <div class=\"todo-add__group\">\n            <label for=\"title\">New todo</label>\n            <input\n                type=\"text\"\n                id=\"title\"\n                name=\"title\"\n                placeholder=\"What do you need to do?\"\n                maxlength=\"300\"\n                autocomplete=\"off\"\n                aria-describedby=\"add-todo-error\"\n                {% if error_message.is_some() %}aria-invalid=\"true\"{% endif %}\n            >\n        </div>\n        <button type=\"submit\" class=\"todo-add__submit\">Add todo</button>\n    </form>\n\n    <p class=\"todo-add__error\" id=\"add-todo-error\" role=\"alert\">{% if let Some(error) = error_message %}{{ error }}{% endif %}</p>\n\n    {% if todos.is_empty() %}\n    <p class=\"todo-empty\">No todos yet.</p>\n    {% else %}\n    <ul class=\"todo-list\" role=\"list\">\n        {% for todo in todos %}\n        <li class=\"todo-item{% if todo.is_completed %} todo-item--completed{% endif %}\">\n            <form method=\"post\" action=\"/todos/{{ todo.id }}/toggle\" class=\"todo-item__toggle-form\">\n                <button type=\"submit\" class=\"todo-item__toggle\"\n                    aria-label=\"{% if todo.is_completed %}Mark &quot;{{ todo.title }}&quot; as pending{% else %}Mark &quot;{{ todo.title }}&quot; as complete{% endif %}\">\n                    {% if todo.is_completed %}&#x2611;{% else %}&#x2610;{% endif %}\n                </button>\n            </form>\n            <span class=\"todo-item__title\">{{ todo.title }}</span>\n            <a href=\"/todos/{{ todo.id }}/edit\" class=\"todo-item__edit\"\n                aria-label=\"Edit &quot;{{ todo.title }}&quot;\">\n                &#x270E;\n            </a>\n            <details class=\"todo-item__delete-confirm\">\n                <summary class=\"todo-item__delete\" aria-label=\"Delete &quot;{{ todo.title }}&quot;\">&#x2715;</summary>\n                <form method=\"post\" action=\"/todos/{{ todo.id }}/delete\">\n                    <span>Delete?</span>\n                    <button type=\"submit\" class=\"todo-item__delete-yes\">Yes</button>\n                </form>\n            </details>\n        </li>\n        {% endfor %}\n    </ul>\n    {% endif %}\n</div>\n{% endblock %}\n","numLines":64,"startLine":1,"totalLines":64}},"sourceToolAssistantUUID":"91788162-82dd-4b7b-8009-92647465e15e"}
